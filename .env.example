# Copy this file to .env and fill in your values.
# The server reads these via the ${VAR_NAME} syntax in config.yaml.

# InfluxDB connection (URL defaults to http://localhost:8086 on the Pi)
# Override when developing locally against a remote InfluxDB:
# INFLUXDB_URL=http://hebepi:8086

# InfluxDB 2.x API token (generated in InfluxDB UI → Data → API Tokens)
INFLUXDB_TOKEN=your-influxdb-api-token-here

# InfluxDB organisation and bucket names (must match your InfluxDB setup)
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET=signalk

# Vessel name shown in the dashboard header
VESSEL_NAME=MY BOAT

# Optional: override the Chromium/Chrome path (useful for local macOS dev).
# config.yaml defaults to /usr/bin/chromium-browser (Raspberry Pi).
# macOS — Brave Browser:
# CHROMIUM_PATH=/Applications/Brave Browser 3.app/Contents/MacOS/Brave Browser
# macOS — Google Chrome:
# CHROMIUM_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
